#!/bin/bash
# zel — Zombie Event Log CLI
# Query passive suspend/resume telemetry written by /usr/lib/systemd/system-sleep/50-zel.

set -u

# Locate the lib dir.
# Order:
#   1. ZEL_LIB_DIR env override (test/CI use)
#   2. dev tree relative to this script (running from a checkout)
#   3. system install paths
# This way `./bin/zel` from a dev checkout uses dev libs even if /usr/local
# has an older installed copy.
if [ -n "${ZEL_LIB_DIR:-}" ] && [ -f "${ZEL_LIB_DIR}/core.sh" ]; then
    :   # use the override
else
    _zel_script_dir="$(cd "$(dirname "$(readlink -f "$0")")" 2>/dev/null && pwd)"
    _zel_dev_lib="${_zel_script_dir}/../lib"
    if [ -f "${_zel_dev_lib}/core.sh" ]; then
        ZEL_LIB_DIR="$(cd "${_zel_dev_lib}" && pwd)"
    elif [ -d /usr/local/share/zel/lib ]; then
        ZEL_LIB_DIR=/usr/local/share/zel/lib
    elif [ -d /usr/share/zel/lib ]; then
        ZEL_LIB_DIR=/usr/share/zel/lib
    fi
    unset _zel_script_dir _zel_dev_lib
fi
export ZEL_LIB_DIR

if [ ! -f "$ZEL_LIB_DIR/core.sh" ]; then
    echo "zel: cannot locate core.sh (looked at $ZEL_LIB_DIR)" >&2
    exit 1
fi

# shellcheck source=../lib/core.sh
source "$ZEL_LIB_DIR/core.sh"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    stats)        zel_stats "$@" ;;
    last)         zel_last "$@" ;;
    catastrophic) zel_catastrophic "$@" ;;
    list)         zel_list "$@" ;;
    show)         zel_show "$@" ;;
    reclassify)   zel_reclassify "$@" ;;
    compare)      zel_compare "$@" ;;
    export)       zel_export "$@" ;;
    doctor)       zel_doctor "$@" ;;
    version|--version|-v) echo "zel $ZEL_VERSION" ;;
    help|--help|-h) zel_help ;;
    *)            echo "zel: unknown command: $cmd"; echo; zel_help; exit 2 ;;
esac
